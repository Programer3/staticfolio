---
import Icon from './Icon.astro';

interface Props {
  href?: string;
  variant?: 'primary' | 'ghost' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  type?: 'button' | 'submit';
  label?: string;
  icon?: string;
  iconRight?: string;
  download?: boolean;
  class?: string;
  cursorLabel?: string;
}
const {
  href,
  variant = 'primary',
  size = 'md',
  type = 'button',
  label,
  icon,
  iconRight,
  download = false,
  class: className = '',
  cursorLabel,
} = Astro.props;

const Tag = href ? 'a' : 'button';
const cls = [
  'mb magnetic',
  `mb--${variant}`,
  `mb--${size}`,
  className,
]
  .filter(Boolean)
  .join(' ');
---

<Tag
  class={cls}
  href={href}
  type={href ? undefined : type}
  download={download ? '' : undefined}
  data-magnetic
  data-cursor-label={cursorLabel}
  data-mb-strength={variant === 'primary' ? '0.4' : '0.3'}
>
  <span class="mb-inner">
    {icon && <Icon slug={icon} size={size === 'lg' ? 18 : 16} class="mb-icon" />}
    {label && <span class="mb-label">{label}</span>}
    {iconRight && <Icon slug={iconRight} size={size === 'lg' ? 18 : 16} class="mb-icon" />}
  </span>
</Tag>