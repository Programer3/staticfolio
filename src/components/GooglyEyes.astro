---
---
<button type="button" class="eyes glass" data-googly-eyes aria-label="hello (blink)" data-cursor-label="hi">
  <span class="eye"><span class="pupil" data-pupil></span></span>
  <span class="eye"><span class="pupil" data-pupil></span></span>
</button>

<style>
  .eyes {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.4rem 0.7rem;
    border-radius: 999px;
    cursor: pointer;
    user-select: none;
    transition: transform 0.2s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .eyes:hover { transform: translateY(-1px); }
  .eyes:active { transform: scale(0.94); }
  .eye {
    position: relative;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #fff;
    border: 1px solid color-mix(in srgb, var(--t-text) 25%, transparent);
    overflow: hidden;
  }
  .pupil {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 7px;
    height: 7px;
    margin: -3.5px 0 0 -3.5px;
    border-radius: 50%;
    background: #111;
    transition: transform 0.12s ease-out;
    will-change: transform;
  }
  .eyes.blink .eye {
    animation: blink 0.32s ease-in-out;
  }
  @keyframes blink {
    0%, 100% { transform: scaleY(1); }
    45%, 55% { transform: scaleY(0.1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .eyes.blink .eye { animation: none; }
    .pupil { transition: none; }
  }
</style>

<script>
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const buttons = Array.from(document.querySelectorAll<HTMLElement>('[data-googly-eyes]'));
  if (buttons.length && !reduce) {
    const instances = buttons.map((btn) => ({
      btn,
      pupils: Array.from(btn.querySelectorAll<HTMLElement>('[data-pupil]')),
      eyes: Array.from(btn.querySelectorAll<HTMLElement>('.eye')),
      visible: false,
    }));

    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        const inst = instances.find((i) => i.btn === e.target);
        if (inst) inst.visible = e.isIntersecting;
      });
    });
    instances.forEach((i) => io.observe(i.btn));

    addEventListener('pointermove', (e) => {
      instances.forEach(({ btn, pupils, visible }) => {
        if (!visible) return;
        const r = btn.getBoundingClientRect();
        const cx = r.left + r.width / 2;
        const cy = r.top + r.height / 2;
        const dx = e.clientX - cx;
        const dy = e.clientY - cy;
        const dist = Math.hypot(dx, dy) || 1;
        const max = 3.5;
        const k = Math.min(max, dist * 0.06) / dist;
        const tx = dx * k;
        const ty = dy * k;
        pupils.forEach((p) => (p.style.transform = `translate(${tx}px, ${ty}px)`));
      });
    }, { passive: true });

    instances.forEach(({ btn }) => {
      btn.addEventListener('click', () => {
        btn.classList.remove('blink');
        void btn.offsetWidth;
        btn.classList.add('blink');
        setTimeout(() => btn.classList.remove('blink'), 360);
      });
    });
  }
</script>