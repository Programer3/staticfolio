---
import { themes, defaultThemeId } from '../data/themes';
---

<div class="switcher" data-theme-switcher>
  <button
    type="button"
    class="trigger glass"
    aria-haspopup="menu"
    aria-expanded="false"
    aria-label="Change theme"
    data-cursor-label="theme"
  >
    <span class="trigger-glyph" data-current-glyph>🐼</span>
    <span class="trigger-label" data-current-label>Panda</span>
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
      <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <div class="menu glass-strong" role="menu" aria-label="Themes" hidden style="background: transparent; -webkit-backdrop-filter: blur(20px) saturate(150%); backdrop-filter: blur(20px) saturate(150%); border: 1px solid var(--t-border-strong);">
    {
      themes.map((t) => (
        <button
          type="button"
          class="menu-item"
          role="menuitemradio"
          aria-checked={t.id === defaultThemeId ? 'true' : 'false'}
          data-theme-id={t.id}
          data-cursor-label={t.label}
        >
          <span class="mi-glyph">{t.glyph}</span>
          <span class="mi-text">
            <span class="mi-label">{t.label}</span>
            <span class="mi-vibe">{t.tokens.vibe}</span>
          </span>
          <span class="mi-swatches" aria-hidden="true">
            <i style={`background:${t.tokens.bg}`} />
            <i style={`background:${t.tokens.accent}`} />
            <i style={`background:${t.tokens.accent2}`} />
          </span>
        </button>
      ))
    }
  </div>
</div>

<style>
  .switcher {
    position: relative;
    display: inline-flex;
  }
  .trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-family: var(--font-mono);
    color: var(--t-text);
    cursor: pointer;
    user-select: none;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .trigger:hover {
    border-color: var(--t-border-strong);
  }
  .trigger-glyph {
    font-size: 1rem;
    line-height: 1;
  }
  .trigger-label {
    max-width: 9ch;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .menu {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    min-width: 16rem;
    padding: 0.4rem;
    border-radius: 16px;
    display: grid;
    gap: 0.15rem;
    transform-origin: top right;
    animation: menu-in 0.18s cubic-bezier(0.2, 0.8, 0.2, 1);
    z-index: 50;
  }
  @keyframes menu-in {
    from {
      opacity: 0;
      transform: translateY(-6px) scale(0.96);
    }
  }
  .menu-item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.65rem;
    padding: 0.55rem 0.65rem;
    border-radius: 10px;
    background: transparent;
    border: 0;
    color: var(--t-text);
    cursor: pointer;
    text-align: left;
    font: inherit;
    transition: background 0.15s ease;
  }
  .menu-item:hover,
  .menu-item:focus-visible {
    background: var(--t-surface);
  }
  .menu-item[aria-checked='true'] {
    background: color-mix(in srgb, var(--t-accent) 14%, transparent);
  }
  .mi-glyph {
    font-size: 1.15rem;
    width: 1.6rem;
    text-align: center;
  }
  .mi-text {
    display: grid;
    gap: 0.1rem;
  }
  .mi-label {
    font-size: 0.85rem;
    font-weight: 600;
  }
  .mi-vibe {
    font-size: 0.7rem;
    font-family: var(--font-mono);
    color: var(--t-text-muted);
  }
  .mi-swatches {
    display: flex;
    gap: 0.2rem;
  }
  .mi-swatches i {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 3px;
    border: 1px solid var(--t-border);
  }
</style>

<script>
  const root = document.querySelector<HTMLElement>('[data-theme-switcher]');
  if (root) {
    const trigger = root.querySelector<HTMLButtonElement>('.trigger')!;
    const menu = root.querySelector<HTMLDivElement>('.menu')!;
    const items = Array.from(
      root.querySelectorAll<HTMLButtonElement>('[data-theme-id]')
    );
    const glyph = root.querySelector<HTMLElement>('[data-current-glyph]')!;
    const label = root.querySelector<HTMLElement>('[data-current-label]')!;

    let activeIdx = 0;

    const apply = (id: string) => {
      document.documentElement.dataset.theme = id;
      try { localStorage.setItem('folio-theme', id); } catch { /* ignore */ }
      sync();
    };

    const sync = () => {
      const id = document.documentElement.dataset.theme || 'panda';
      const active = items.find((i) => i.dataset.themeId === id);
      activeIdx = active ? items.indexOf(active) : 0;
      items.forEach((i) =>
        i.setAttribute('aria-checked', i === active ? 'true' : 'false')
      );
      if (active) {
        glyph.textContent = active.querySelector('.mi-glyph')?.textContent ?? '';
        label.textContent = active.querySelector('.mi-label')?.textContent ?? '';
      }
    };

    const open = () => {
      menu.hidden = false;
      trigger.setAttribute('aria-expanded', 'true');
      items[activeIdx]?.focus();
    };
    const close = () => {
      menu.hidden = true;
      trigger.setAttribute('aria-expanded', 'false');
    };

    trigger.addEventListener('click', () =>
      menu.hidden ? open() : close()
    );
    trigger.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown' || e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        open();
      }
    });

    const move = (delta: number) => {
      activeIdx = (activeIdx + delta + items.length) % items.length;
      const item = items[activeIdx];
      item.focus();
      apply(item.dataset.themeId!);
    };

    items.forEach((item) => {
      item.addEventListener('click', () => {
        apply(item.dataset.themeId!);
        close();
        trigger.focus();
      });
      item.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowDown') { e.preventDefault(); move(1); }
        else if (e.key === 'ArrowUp') { e.preventDefault(); move(-1); }
        else if (e.key === 'Enter') { e.preventDefault(); close(); trigger.focus(); }
        else if (e.key === 'Escape') { e.preventDefault(); close(); trigger.focus(); }
        else if (e.key === 'Tab') { close(); }
        else if (e.key.length === 1) { close(); trigger.focus(); }
      });
    });

    document.addEventListener('click', (e) => {
      if (!root.contains(e.target as Node)) close();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });

    sync();
  }
</script>