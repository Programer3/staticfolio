---
/**
 * Cursor — custom dual-element cursor (dot + trailing ring).
 * - Disabled on touch / coarse pointers via CSS + JS guard.
 * - Respects prefers-reduced-motion (renders nothing).
 * - Ring grows + labels on [data-cursor-label] hover targets.
 * - mix-blend-mode: difference makes it visible on any theme.
 */
---
<div class="cursor-root" data-cursor aria-hidden="true">
  <div class="cursor-dot"></div>
  <div class="cursor-ring">
    <span class="cursor-label"></span>
  </div>
</div>

<style>
  .cursor-root {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 9998;
    pointer-events: none;
    mix-blend-mode: difference;
  }
  .cursor-dot {
    position: absolute;
    width: 7px;
    height: 7px;
    margin: -3.5px 0 0 -3.5px;
    background: #fff;
    border-radius: 50%;
    will-change: transform;
  }
  .cursor-ring {
    position: absolute;
    width: 38px;
    height: 38px;
    margin: -19px 0 0 -19px;
    border: 1.5px solid #fff;
    border-radius: 50%;
    display: grid;
    place-items: center;
    transition:
      width 0.25s cubic-bezier(0.2, 0.8, 0.2, 1),
      height 0.25s cubic-bezier(0.2, 0.8, 0.2, 1),
      margin 0.25s cubic-bezier(0.2, 0.8, 0.2, 1),
      background 0.2s ease,
      border-color 0.2s ease;
    will-change: transform;
  }
  .cursor-ring.is-active {
    width: 64px;
    height: 64px;
    margin: -32px 0 0 -32px;
    background: rgba(255, 255, 255, 0.12);
  }
  .cursor-label {
    font: 600 10px/1 ui-monospace, monospace;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0;
    transform: scale(0.6);
    transition:
      opacity 0.18s ease 0.04s,
      transform 0.18s ease 0.04s;
    white-space: nowrap;
    text-align: center;
  }
  .cursor-ring.is-active .cursor-label {
    opacity: 1;
    transform: scale(1);
  }
  @media (hover: none), (pointer: coarse) {
    .cursor-root {
      display: none;
    }
  }
</style>

<script>
  // ── Custom cursor: smooth-follow ring + instant dot ────────────────────
  const root = document.querySelector<HTMLElement>('.cursor-root');
  const dot = document.querySelector<HTMLElement>('.cursor-dot');
  const ring = document.querySelector<HTMLElement>('.cursor-ring');
  const label = document.querySelector<HTMLElement>('.cursor-label');

  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const touch = matchMedia('(hover: none), (pointer: coarse)').matches;

  if (root && dot && ring && label && !reduce && !touch) {
    let mx = window.innerWidth / 2;
    let my = window.innerHeight / 2;
    let rx = mx;
    let ry = my;
    let raf = 0;

    const tick = () => {
      // ease ring toward the pointer
      rx += (mx - rx) * 0.18;
      ry += (my - ry) * 0.18;
      dot.style.transform = `translate3d(${mx}px, ${my}px, 0)`;
      ring.style.transform = `translate3d(${rx}px, ${ry}px, 0)`;
      raf = requestAnimationFrame(tick);
    };
    tick();

    addEventListener(
      'mousemove',
      (e) => {
        mx = e.clientX;
        my = e.clientY;
      },
      { passive: true }
    );

    // Hide when pointer leaves the window
    document.addEventListener('mouseleave', () => (root.style.opacity = '0'));
    document.addEventListener('mouseenter', () => (root.style.opacity = '1'));

    // Grow ring + show label on interactive targets
    const activate = (el: Element) => {
      ring.classList.add('is-active');
      const t = (el as HTMLElement).dataset.cursorLabel;
      label.textContent = t ?? '';
      ring.style.borderColor = t ? 'transparent' : '#fff';
    };
    const deactivate = () => {
      ring.classList.remove('is-active');
      label.textContent = '';
      ring.style.borderColor = '#fff';
    };

    // Delegate: any element with [data-cursor-label] or a/button/summary
    const isTarget = (el: Element | null): el is HTMLElement =>
      !!el &&
      (el instanceof HTMLElement) &&
      (!!el.dataset.cursorLabel ||
        ['A', 'BUTTON', 'SUMMARY', 'INPUT', 'TEXTAREA'].includes(el.tagName));

    document.addEventListener('mouseover', (e) => {
      const el = (e.target as HTMLElement)?.closest('[data-cursor-label], a, button, summary');
      if (el && isTarget(el)) activate(el);
    });
    document.addEventListener('mouseout', (e) => {
      const el = (e.target as HTMLElement)?.closest('[data-cursor-label], a, button, summary');
      if (el && isTarget(el)) {
        const next = (e as MouseEvent).relatedTarget as HTMLElement | null;
        if (!next || !next.closest('[data-cursor-label], a, button, summary'))
          deactivate();
      }
    });
  } else if (root) {
    root.remove();
  }
</script>
