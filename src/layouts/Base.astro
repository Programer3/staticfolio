---
import '../styles/global.css';
import { portfolio } from '../data/portfolio';
import GrainOverlay from '../components/GrainOverlay.astro';
import Cursor from '../components/Cursor.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${portfolio.name} — ${portfolio.role}`,
  description = portfolio.proposition,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://example.com');
---

<!doctype html>
    <html lang="en" data-theme="panda">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    <meta name="color-scheme" content="dark light" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={portfolio.name} />
    <meta name="theme-color" content="#0d0d0f" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f4f1ea" media="(prefers-color-scheme: light)" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="/og-image.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-image.svg" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="preconnect" href="/" crossorigin />

    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('folio-theme');
          var theme = stored || 'panda';
          document.documentElement.setAttribute('data-theme', theme);
          window.__folioTheme = theme;
        } catch (e) {
          /* localStorage blocked */
        }
      })();
    </script>

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: portfolio.name,
        jobTitle: portfolio.role,
        url: canonical.origin,
        email: `mailto:${portfolio.email}`,
        sameAs: portfolio.socials
          .filter((s) => !s.href.startsWith('mailto'))
          .map((s) => s.href),
      })}
    />

    <meta name="robots" content="index,follow" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>

    <div class="site-grid" aria-hidden="true"></div>
    <div class="site-ambient" aria-hidden="true">
      <span class="amb-orb amb-1"></span>
      <span class="amb-orb amb-2"></span>
    </div>
    <GrainOverlay />
    <Cursor />

    <slot />

    <script is:inline>
      console.log(
        '%c↑ looking under the hood? nice. %c\n%c%s%c\n%c%s',
        'font:600 14px ui-monospace,monospace;color:#a78bfa;',
        '',
        'font:600 18px ui-monospace,monospace;color:#22d3ee;',
        '      _  _\n     | || |   the source is the portfolio.\n     | || |   — pull requests welcome.\n     |____|\n',
        '',
        'font:400 12px ui-monospace,monospace;color:#71717a;',
        ''
      );
    </script>
  </body>
</html>