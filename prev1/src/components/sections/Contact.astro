---
// Contact Section — "The Signal Station"
import { socialLinks } from "../../lib/data/social";

// Brand icons (24x24, currentColor). Returns SVG inner markup per icon key.
const socialIcons: Record<string, string> = {
  github: '<path d="M12 .5A11.5 11.5 0 0 0 .5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.78 1.2 1.78 1.2 1.04 1.79 2.73 1.27 3.4.97.1-.76.4-1.27.74-1.56-2.56-.29-5.25-1.28-5.25-5.7 0-1.26.45-2.29 1.2-3.1-.12-.3-.52-1.48.1-3.08 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.2-1.5 3.17-1.18 3.17-1.18.63 1.6.23 2.78.11 3.07.75.82 1.2 1.85 1.2 3.11 0 4.43-2.7 5.4-5.27 5.69.42.36.78 1.05.78 2.12v3.14c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5Z"/>',
  linkedin: '<path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14ZM7.12 20.45H3.56V9h3.56v11.45ZM22.22 0H1.77C.8 0 0 .78 0 1.74v20.51C0 23.22.8 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.75V1.74C24 .78 23.2 0 22.22 0Z"/>',
  twitter: '<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231L18.244 2.25Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z"/>',
};

// Mail uses stroke rendering (outline envelope) — fill-based rect looks solid
const mailIconSvg = '<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>';

function socialIconSvg(icon: string): string {
  if (icon === 'mail') return mailIconSvg;
  const inner = socialIcons[icon] ?? socialIcons.twitter;
  return `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">${inner}</svg>`;
}
---

<section
  id="contact"
  class="py-20 sm:py-28 relative z-10 px-4 sm:px-6 lg:px-8"
>
  <div class="max-w-[1200px] mx-auto">
    <div class="mb-12">
      <span class="micro-label text-accent">// 03</span>
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-fg mt-2 tracking-tighter">
        Send a Signal
      </h2>
      <p class="font-body text-fg-muted mt-3 max-w-xl leading-relaxed">
        Got a project, a question, or just want to say hi? Drop a message.
      </p>
    </div>

    <div class="grid lg:grid-cols-[1fr_auto] gap-8 lg:gap-16">
      <form id="contact-form" class="space-y-5 max-w-xl" novalidate>
        <div>
          <label for="name" class="micro-label block mb-1.5">Name</label>
          <input type="text" id="name" name="name" required placeholder="Your name"
            class="w-full px-4 py-3 rounded-xl bg-muted/30 border border-card-border text-fg placeholder:text-fg-muted/40 font-body text-sm focus-visible:ring-ring/50 focus-visible:ring-[3px] focus-visible:border-ring outline-none transition-all" />
          <span class="error-message text-destructive text-[11px] font-code mt-1 hidden" data-for="name">Name is required</span>
        </div>
        <div>
          <label for="email" class="micro-label block mb-1.5">Email</label>
          <input type="email" id="email" name="email" required maxlength="100" placeholder="you@example.com"
            class="w-full px-4 py-3 rounded-xl bg-muted/30 border border-card-border text-fg placeholder:text-fg-muted/40 font-body text-sm focus-visible:ring-ring/50 focus-visible:ring-[3px] focus-visible:border-ring outline-none transition-all" />
          <span class="error-message text-destructive text-[11px] font-code mt-1 hidden" data-for="email">Valid email is required</span>
        </div>
        <div>
          <label for="message" class="micro-label block mb-1.5">Message</label>
          <textarea id="message" name="message" required rows="4" placeholder="What's on your mind?"
            class="w-full px-4 py-3 rounded-xl bg-muted/30 border border-card-border text-fg placeholder:text-fg-muted/40 font-body text-sm focus-visible:ring-ring/50 focus-visible:ring-[3px] focus-visible:border-ring outline-none transition-all resize-none"
            style="scrollbar-width: thin; scrollbar-color: var(--theme-muted) transparent;"></textarea>
          <span class="error-message text-destructive text-[11px] font-code mt-1 hidden" data-for="message">Message must be at least 10 characters</span>
        </div>
        <button type="submit" class="command-strip font-bold text-sm px-8 py-3 rounded-full shadow-glow hover:-translate-y-0.5 hover:shadow-lg transition-all duration-200 magnetic-btn inline-flex items-center gap-2" data-magnetic="true">
          Send Signal
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        </button>
        <div id="form-success" class="hidden text-accent font-body text-sm animate-scale-in">Signal sent! I'll get back to you soon.</div>
      </form>

      <div class="space-y-4 w-full lg:w-auto">
        <div class="paper-card p-5 min-w-[200px]">
          <h3 class="micro-label mb-3">Connect</h3>
          <div class="space-y-3">
            {socialLinks.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 text-fg-muted hover:text-fg transition-colors group"
                aria-label={link.label}
              >
                <span class="w-8 h-8 rounded-lg bg-muted/30 flex items-center justify-center group-hover:bg-primary/20 transition-colors" set:html={socialIconSvg(link.icon)} />
                <span class="font-body text-sm">{link.name}</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <footer class="mt-20 pt-8 border-t border-card-border flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2 font-code text-[10px] text-fg-muted">
        <span>2026 Chaman</span>
        <span class="text-fg-muted/30">·</span>
        <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">Built with Astro</a>
        <span class="text-fg-muted/30">·</span>
        <a href="https://github.com/Programer3/Dev-folio" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">v1.0.0</a>
      </div>
      <div class="font-code text-[10px] text-fg-muted cursor-pointer hover:text-accent transition-colors" id="snake-trigger" title="Play Snake">
        <pre class="leading-none">[  ~/chaman/portfolio  ]</pre>
      </div>
    </footer>
  </div>
</section>

<script>
  // Contact form logic
  var form = document.getElementById("contact-form");
  var nameInput = document.getElementById("name");
  var emailInput = document.getElementById("email");
  var messageInput = document.getElementById("message");
  var successMsg = document.getElementById("form-success");
  var errors = form.querySelectorAll(".error-message");

  function showError(inputId) {
    errors.forEach(function (e) { if (e.dataset.for === inputId) e.classList.remove("hidden"); });
  }
  function clearErrors() {
    errors.forEach(function (e) { e.classList.add("hidden"); });
  }

  form.addEventListener("submit", async function (e) {
    e.preventDefault();
    clearErrors();
    var valid = true;
    if (!nameInput.value.trim()) { showError("name"); valid = false; }
    if (!emailInput.value.trim() || !emailInput.validity.valid) { showError("email"); valid = false; }
    if (!messageInput.value.trim() || messageInput.value.trim().length < 10) { showError("message"); valid = false; }
    if (!valid) return;
    try {
      await new Promise(function (r) { setTimeout(r, 800); });
      form.reset();
      form.classList.add("hidden");
      successMsg.classList.remove("hidden");
      try {
        var c = await import("canvas-confetti");
        c.default({ particleCount: 120, spread: 80, origin: { y: 0.6 }, colors: ["#ffba49", "#20a39e", "#adaabf"] });
      } catch (_) {}
    } catch (_) {
      alert("Something went wrong. Try emailing me directly.");
    }
  });

  // Snake game trigger — opens in a modal with canvas-based snake
  document.getElementById("snake-trigger").addEventListener("click", function () {
    var overlay = document.createElement("div");
    overlay.className = "fixed inset-0 z-[100] flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm animate-scale-in";

    var modal = document.createElement("div");
    modal.className = "glass-panel max-w-sm w-full p-6 relative animate-fade-up";
    modal.onclick = function (e) { e.stopPropagation(); };

    modal.innerHTML =
      '<button class="absolute top-3 right-3 text-fg-muted hover:text-fg text-xl transition-colors" aria-label="Close">&times;</button>' +
      '<h3 class="font-display text-lg font-bold text-fg mb-2 text-center">Snake</h3>' +
      '<div class="flex items-center justify-between mb-2">' +
        '<span class="font-code text-xs text-fg-muted" id="snake-score">Score: 0</span>' +
        '<span class="font-code text-xs text-fg-muted" id="snake-status">Arrow keys to start</span>' +
      '</div>' +
      '<canvas id="snake-canvas" width="252" height="252" style="display:block;margin:0 auto;border-radius:6px;border:1px solid var(--theme-card-border);background:var(--theme-bg-alt);image-rendering:pixelated;"></canvas>' +
      '<p class="font-code text-[10px] text-fg-muted/50 text-center mt-2">WASD / Arrows · Wraps edges · Auto-restarts</p>';

    // Memory management: track all resources for cleanup
    var animFrameId = null;
    var keyHandler = null;
    var touchStartHandler = null;
    var touchEndHandler = null;
    var restartTimeout = null;
    var isDestroyed = false;

    function cleanup() {
      isDestroyed = true;
      if (animFrameId) { cancelAnimationFrame(animFrameId); animFrameId = null; }
      if (restartTimeout) { clearTimeout(restartTimeout); restartTimeout = null; }
      if (keyHandler) { document.removeEventListener("keydown", keyHandler); keyHandler = null; }
      if (touchStartHandler) { canvas.removeEventListener("touchstart", touchStartHandler); touchStartHandler = null; }
      if (touchEndHandler) { canvas.removeEventListener("touchend", touchEndHandler); touchEndHandler = null; }
      overlay.remove();
    }

    overlay.onclick = cleanup;
    modal.querySelector("button").onclick = cleanup;

    overlay.appendChild(modal);
    document.body.appendChild(overlay);

    // Snake game logic
    var canvas = document.getElementById("snake-canvas");
    var ctx = canvas.getContext("2d");
    var GRID = 18;
    var CELL = 14;
    canvas.width = GRID * CELL;
    canvas.height = GRID * CELL;

    // Read theme colors
    var cs = getComputedStyle(document.documentElement);
    var colorBg = cs.getPropertyValue("--theme-bg-alt").trim() || "#1a1a2e";
    var colorSnake = cs.getPropertyValue("--theme-primary").trim() || "#ffba49";
    var colorFood = cs.getPropertyValue("--theme-accent").trim() || "#20a39e";
    var colorHead = cs.getPropertyValue("--theme-fg").trim() || "#f0f0f0";

    var snake, dir, nextDir, food, score, gameOver, started, lastTick;
    var TICK = 140; // ms per game step

    function initGame() {
      var mid = Math.floor(GRID / 2);
      snake = [{ x: mid, y: mid }, { x: mid - 1, y: mid }, { x: mid - 2, y: mid }];
      dir = { x: 1, y: 0 };
      nextDir = { x: 1, y: 0 };
      food = null;
      score = 0;
      gameOver = false;
      started = false;
      lastTick = 0;
      placeFood();
      updateUI();
      draw();
    }

    function placeFood() {
      var attempts = 0;
      while (attempts < 500) {
        var fx = Math.floor(Math.random() * GRID);
        var fy = Math.floor(Math.random() * GRID);
        var onSnake = false;
        for (var i = 0; i < snake.length; i++) {
          if (snake[i].x === fx && snake[i].y === fy) { onSnake = true; break; }
        }
        if (!onSnake) { food = { x: fx, y: fy }; return; }
        attempts++;
      }
    }

    function updateUI() {
      var scoreEl = document.getElementById("snake-score");
      var statusEl = document.getElementById("snake-status");
      if (scoreEl) scoreEl.textContent = "Score: " + score;
      if (statusEl) {
        if (gameOver) statusEl.textContent = "Game Over!";
        else if (!started) statusEl.textContent = "Arrow keys to start";
        else statusEl.textContent = "Playing...";
      }
    }

    function step() {
      dir = nextDir;
      var head = { x: (snake[0].x + dir.x + GRID) % GRID, y: (snake[0].y + dir.y + GRID) % GRID };

      // Self-collision check
      for (var i = 0; i < snake.length; i++) {
        if (snake[i].x === head.x && snake[i].y === head.y) {
          gameOver = true;
          updateUI();
          // Auto-restart after 1.5s
          restartTimeout = setTimeout(function () {
            if (!isDestroyed) initGame();
          }, 1500);
          return;
        }
      }

      snake.unshift(head);

      // Food check
      if (food && head.x === food.x && head.y === food.y) {
        score++;
        placeFood();
        updateUI();
      } else {
        snake.pop();
      }
    }

    function draw() {
      // Re-read theme colors on each draw (for live theme switching)
      cs = getComputedStyle(document.documentElement);
      colorBg = cs.getPropertyValue("--theme-bg-alt").trim() || "#1a1a2e";
      colorSnake = cs.getPropertyValue("--theme-primary").trim() || "#ffba49";
      colorFood = cs.getPropertyValue("--theme-accent").trim() || "#20a39e";
      colorHead = cs.getPropertyValue("--theme-fg").trim() || "#f0f0f0";

      ctx.fillStyle = colorBg;
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      // Draw food
      if (food) {
        ctx.fillStyle = colorFood;
        ctx.beginPath();
        ctx.arc(food.x * CELL + CELL / 2, food.y * CELL + CELL / 2, CELL / 2 - 1, 0, Math.PI * 2);
        ctx.fill();
      }

      // Draw snake
      for (var i = 0; i < snake.length; i++) {
        ctx.fillStyle = i === 0 ? colorHead : colorSnake;
        var r = i === 0 ? 4 : 3;
        ctx.beginPath();
        ctx.roundRect(snake[i].x * CELL + 1, snake[i].y * CELL + 1, CELL - 2, CELL - 2, r);
        ctx.fill();
      }
    }

    function loop(timestamp) {
      if (isDestroyed) return;
      if (!gameOver && started) {
        if (timestamp - lastTick >= TICK) {
          step();
          lastTick = timestamp;
        }
      }
      draw();
      animFrameId = requestAnimationFrame(loop);
    }

    keyHandler = function (e) {
      if (isDestroyed) return;
      var key = e.key;
      if (key === "ArrowUp" || key === "w" || key === "W") {
        if (dir.y !== 1) { nextDir = { x: 0, y: -1 }; if (!started) started = true; }
        e.preventDefault();
      } else if (key === "ArrowDown" || key === "s" || key === "S") {
        if (dir.y !== -1) { nextDir = { x: 0, y: 1 }; if (!started) started = true; }
        e.preventDefault();
      } else if (key === "ArrowLeft" || key === "a" || key === "A") {
        if (dir.x !== 1) { nextDir = { x: -1, y: 0 }; if (!started) started = true; }
        e.preventDefault();
      } else if (key === "ArrowRight" || key === "d" || key === "D") {
        if (dir.x !== -1) { nextDir = { x: 1, y: 0 }; if (!started) started = true; }
        e.preventDefault();
      } else if (key === "Escape") {
        cleanup();
      }
    };

    // Touch support for mobile
    var touchStartX = 0, touchStartY = 0;
    touchStartHandler = function (e) {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
    };
    touchEndHandler = function (e) {
      if (isDestroyed) return;
      var dx = e.changedTouches[0].clientX - touchStartX;
      var dy = e.changedTouches[0].clientY - touchStartY;
      if (Math.abs(dx) < 10 && Math.abs(dy) < 10) return;
      if (Math.abs(dx) > Math.abs(dy)) {
        if (dx > 0 && dir.x !== -1) { nextDir = { x: 1, y: 0 }; }
        else if (dx < 0 && dir.x !== 1) { nextDir = { x: -1, y: 0 }; }
      } else {
        if (dy > 0 && dir.y !== -1) { nextDir = { x: 0, y: 1 }; }
        else if (dy < 0 && dir.y !== 1) { nextDir = { x: 0, y: -1 }; }
      }
      if (!started) started = true;
    };

    document.addEventListener("keydown", keyHandler);
    canvas.addEventListener("touchstart", touchStartHandler, { passive: true });
    canvas.addEventListener("touchend", touchEndHandler, { passive: true });

    initGame();
    animFrameId = requestAnimationFrame(loop);
  });
</script>