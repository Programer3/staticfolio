---
// Hero Section — "The Command Strip"
// Typewriter effect, magnetic buttons, LOC counter, theme switcher, animated counters
import ThemeSwitcher from "../ui/ThemeSwitcher.astro";
import MagneticButton from "../ui/MagneticButton.astro";
import LocCounter from "../ui/LocCounter.astro";
---

<section
  id="hero"
  class="min-h-screen flex flex-col justify-center relative z-10 px-4 sm:px-6 lg:px-8"
>
  <div class="max-w-[1200px] mx-auto w-full">
    <!-- Top bar: mirrors the grid below so Connect aligns with sidebar left edge -->
    <div class="grid lg:grid-cols-[1fr_auto] gap-8 lg:gap-12 mb-8">
      <div></div>
      <div class="w-full lg:w-56 flex items-center justify-between gap-3">
        <a
          href="#contact"
          class="font-code text-xs px-3 py-1.5 rounded-full border border-card-border text-fg-muted hover:text-accent hover:border-accent transition-all duration-200"
          aria-label="Connect with me"
        >
          Connect
        </a>
        <ThemeSwitcher />
      </div>
    </div>

    <div class="grid lg:grid-cols-[1fr_auto] gap-8 lg:gap-12 items-start">
      <div class="space-y-6 sm:space-y-8">
        <div class="flex items-center gap-2 text-fg-muted">
          <span class="w-2 h-2 rounded-full bg-accent" />
          <span class="font-code text-xs tracking-widest">~/chaman/portfolio</span>
          <span class="text-fg-muted/40">$</span>
        </div>

        <div>
          <h1 class="font-display text-4xl sm:text-5xl lg:text-7xl font-bold text-fg tracking-tighter leading-[1.1]">
            <span class="block">Chaman</span>
            <span class="block text-primary text-3xl sm:text-4xl lg:text-5xl mt-2" id="role-text">
              <span id="typewriter" />
              <span class="animate-glow-pulse">_</span>
            </span>
          </h1>
        </div>

        <p class="font-body text-base sm:text-lg text-fg-muted leading-relaxed max-w-2xl">
          Curious and organized. I solve everyday problems with robust, out-of-the-box thinking —
          algorithms, logic, and maintainability first. I build with the right tool for the problem.
        </p>

        <div class="flex flex-wrap gap-3 sm:gap-4">
          <MagneticButton href="/resume.pdf" variant="primary" label="Download CV" download>
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Download CV
            </span>
          </MagneticButton>
          <MagneticButton href="#projects" variant="outline" label="View Projects">
            <span class="flex items-center gap-2">
              View Projects
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
            </span>
          </MagneticButton>
        </div>

        <div class="flex flex-wrap gap-2 pt-2">
          {["Flutter", "Dart", "Python", "Git", "Firebase", "Supabase"].map((s) => (
            <span class="tag-capsule">
              {s}
            </span>
          ))}
        </div>
      </div>

      <!-- Side panel with animated counters -->
      <div class="w-full lg:w-56 space-y-4">
        <LocCounter />
        <div class="paper-card p-4 space-y-2">
          <div class="flex justify-between text-xs">
            <span class="font-code text-fg-muted">exp</span>
            <span class="font-display font-bold text-fg">
              <span id="counter-exp">0</span><span>+ yrs</span>
            </span>
          </div>
          <div class="flex justify-between text-xs">
            <span class="font-code text-fg-muted">projects</span>
            <span class="font-display font-bold text-fg">
              <span id="counter-projects">0</span><span>+</span>
            </span>
          </div>
          <div class="flex justify-between text-xs">
            <span class="font-code text-fg-muted">focus</span>
            <span class="font-display font-bold text-accent">Mobile</span>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-16 flex flex-col items-center gap-2 text-fg-muted/40">
      <span class="micro-label text-[10px]">Scroll</span>
      <svg class="w-4 h-4 animate-bounce" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
    </div>
  </div>
</section>

<script>
  // Typewriter effect
  var roles = ["Flutter Developer", "Problem Solver", "Systems Thinker", "Open Source Advocate"];
  var roleIndex = 0, charIndex = 0, isDeleting = false;
  var el = document.getElementById("typewriter");
  function type() {
    if (!el) return;
    var current = roles[roleIndex];
    if (!isDeleting) {
      el.textContent = current.substring(0, charIndex + 1);
      charIndex++;
      if (charIndex === current.length) { setTimeout(function () { isDeleting = true; type(); }, 2000); return; }
    } else {
      el.textContent = current.substring(0, charIndex);
      charIndex--;
      if (charIndex < 0) { isDeleting = false; charIndex = 0; roleIndex = (roleIndex + 1) % roles.length; }
    }
    setTimeout(type, isDeleting ? 30 : 80);
  }
  if (el) type();

  // Animated counters: exp=2, projects=15 with ease-out
  function animateCounter(id, target) {
    var el = document.getElementById(id);
    if (!el) return;
    var start = null;
    var duration = 2000; // 2 seconds

    function step(timestamp) {
      if (!start) start = timestamp;
      var progress = Math.min((timestamp - start) / duration, 1);
      // Ease-out cubic
      var eased = 1 - Math.pow(1 - progress, 3);
      var current = Math.round(eased * target);
      el.textContent = String(current);
      if (progress < 1) { requestAnimationFrame(step); }
    }

    // Use IntersectionObserver to start on scroll
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          requestAnimationFrame(step);
          observer.disconnect();
        }
      });
    }, { threshold: 0.5 });
    observer.observe(el.closest(".paper-card") || el);
  }

  animateCounter("counter-exp", 2);
  animateCounter("counter-projects", 15);
</script>