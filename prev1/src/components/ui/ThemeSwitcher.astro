---
// Theme Switcher — Custom styled dropdown with color swatches
// Click trigger to open popover panel, text-based items
// Persists choice in localStorage, smooth transitions
---

<style>
  .theme-switcher-wrap { position: relative; }
  .theme-trigger {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.75rem;
    border-radius: 9999px;
    background: var(--theme-card);
    border: 1px solid var(--theme-card-border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    cursor: pointer;
    transition: border-color 0.2s, box-shadow 0.2s;
    font-family: "IBM Plex Mono", var(--theme-font-code);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--theme-fg-muted);
    white-space: nowrap;
    user-select: none;
  }
  .theme-trigger:hover { border-color: var(--theme-primary); }
  .theme-trigger:focus-visible { outline: 3px solid var(--theme-ring); outline-offset: 2px; }

  .theme-swatch {
    width: 12px; height: 12px;
    border-radius: 50%;
    border: 1.5px solid var(--theme-card-border);
    flex-shrink: 0;
  }
  .theme-chevron {
    width: 10px; height: 10px;
    transition: transform 0.2s;
    flex-shrink: 0;
  }
  .theme-switcher-wrap.open .theme-chevron { transform: rotate(180deg); }

  .theme-panel {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    z-index: 50;
    min-width: 180px;
    max-height: 320px;
    overflow-y: auto;
    background: var(--theme-card);
    border: 1px solid var(--theme-card-border);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: 12px;
    box-shadow: var(--theme-shadow);
    padding: 0.375rem;
    display: none;
    scrollbar-width: thin;
    scrollbar-color: var(--theme-muted) transparent;
    animation: theme-panel-in 0.15s ease-out;
  }
  @keyframes theme-panel-in {
    from { opacity: 0; transform: translateY(-4px) scale(0.97); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  .theme-switcher-wrap.open .theme-panel {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .theme-option {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.4rem 0.6rem;
    border-radius: 8px;
    border: none;
    background: transparent;
    cursor: pointer;
    font-family: "IBM Plex Mono", var(--theme-font-code);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--theme-fg-muted);
    transition: background 0.15s, color 0.15s;
    text-align: left;
  }
  .theme-option:hover { background: var(--theme-muted); color: var(--theme-fg); }
  .theme-option:focus-visible {
    outline: 2px solid var(--theme-ring);
    outline-offset: -2px;
    background: var(--theme-muted);
    color: var(--theme-fg);
  }
  .theme-option[data-active="true"] {
    background: var(--theme-primary);
    color: var(--theme-bg);
  }
  .theme-option .opt-swatch {
    width: 10px; height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    border: 1px solid rgba(128,128,128,0.3);
  }
</style>

<div class="theme-switcher-wrap" id="theme-wrapper">
  <button
    class="theme-trigger"
    id="theme-trigger"
    aria-haspopup="listbox"
    aria-expanded="false"
    aria-label="Select theme"
    type="button"
  >
    <span class="theme-swatch" id="trigger-swatch"></span>
    <span id="trigger-label">Theme</span>
    <svg class="theme-chevron" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M2 3.5L5 6.5L8 3.5" />
    </svg>
  </button>

  <div class="theme-panel" id="theme-panel" role="listbox" aria-label="Themes">
    <!-- Populated by JS -->
  </div>
</div>

<script>
  (function () {
    var themes = [
      { id: "blueprint",  name: "Blueprint",  color: "#ffba49" },
      { id: "terminal",   name: "Terminal",   color: "#4ade80" },
      { id: "paper",      name: "Paper",      color: "#c8a882" },
      { id: "emerald",    name: "Emerald",    color: "#00674F" },
      { id: "winter",     name: "Winter",     color: "#93c5fd" },
      { id: "dracula",    name: "Dracula",    color: "#ff79c6" },
      { id: "luxury",     name: "Luxury",     color: "#d4a017" },
      { id: "silk",       name: "Silk",       color: "#c08080" },
      { id: "tf2red",     name: "TF2 Red",    color: "#FB524F" },
      { id: "panda",      name: "Panda",      color: "#6ee7b7" },
      { id: "claude",     name: "Claude",     color: "#cc7755" },
      { id: "synthwave",  name: "Synthwave",  color: "#f472b6" },
    ];

    var wrapper = document.getElementById("theme-wrapper");
    var trigger = document.getElementById("theme-trigger");
    var panel = document.getElementById("theme-panel");
    var triggerSwatch = document.getElementById("trigger-swatch");
    var triggerLabel = document.getElementById("trigger-label");
    var root = document.documentElement;
    var isOpen = false;

    // Build option buttons — tabindex="-1" keeps them out of natural tab order;
    // JS manages focus via arrow keys when panel is open
    var html = "";
    for (var i = 0; i < themes.length; i++) {
      var t = themes[i];
      html += '<button class="theme-option" data-theme="' + t.id + '" data-active="false" role="option" tabindex="-1" type="button">'
        + '<span class="opt-swatch" style="background:' + t.color + '"></span>'
        + t.name
        + '</button>';
    }
    panel.innerHTML = html;

    var options = panel.querySelectorAll(".theme-option");

    function applyTheme(theme) {
      root.setAttribute("data-theme", theme);
      root.classList.add("theme-transitioning");
      setTimeout(function () { root.classList.remove("theme-transitioning"); }, 500);

      // Update trigger
      for (var i = 0; i < themes.length; i++) {
        if (themes[i].id === theme) {
          triggerSwatch.style.background = themes[i].color;
          triggerLabel.textContent = themes[i].name;
          break;
        }
      }

      // Update active states
      options.forEach(function (opt) {
        var isActive = opt.dataset.theme === theme;
        opt.dataset.active = String(isActive);
        opt.setAttribute("aria-selected", String(isActive));
      });
    }

    function getFocusedIndex() {
      var arr = Array.prototype.slice.call(options);
      return arr.indexOf(document.activeElement);
    }

    function focusOption(idx) {
      var arr = Array.prototype.slice.call(options);
      if (idx < 0) idx = arr.length - 1;
      if (idx >= arr.length) idx = 0;
      arr[idx].focus();
    }

    function open() {
      isOpen = true;
      wrapper.classList.add("open");
      trigger.setAttribute("aria-expanded", "true");
      // Focus the currently active option, or the first
      var activeIdx = 0;
      options.forEach(function (opt, i) {
        if (opt.dataset.active === "true") activeIdx = i;
      });
      focusOption(activeIdx);
    }

    function close(returnFocus) {
      isOpen = false;
      wrapper.classList.remove("open");
      trigger.setAttribute("aria-expanded", "false");
      if (returnFocus !== false) trigger.focus();
    }

    function toggle() {
      if (isOpen) { close(); } else { open(); }
    }

    // Trigger: click and keyboard
    trigger.addEventListener("click", function (e) {
      e.stopPropagation();
      toggle();
    });
    trigger.addEventListener("keydown", function (e) {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        if (!isOpen) { open(); } else { close(); }
      } else if (e.key === "ArrowDown") {
        e.preventDefault();
        if (!isOpen) open();
        else focusOption(0);
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        if (!isOpen) open();
        else focusOption(options.length - 1);
      }
    });

    // Option buttons: click, keyboard navigation inside list
    options.forEach(function (opt) {
      opt.addEventListener("click", function (e) {
        e.stopPropagation();
        var theme = opt.dataset.theme || "blueprint";
        applyTheme(theme);
        localStorage.setItem("dev-foliio-theme", theme);
        close();
      });

      opt.addEventListener("keydown", function (e) {
        var idx = getFocusedIndex();
        if (e.key === "ArrowDown") {
          e.preventDefault();
          focusOption(idx + 1);
        } else if (e.key === "ArrowUp") {
          e.preventDefault();
          focusOption(idx - 1);
        } else if (e.key === "Home") {
          e.preventDefault();
          focusOption(0);
        } else if (e.key === "End") {
          e.preventDefault();
          focusOption(options.length - 1);
        } else if (e.key === "Enter" || e.key === " ") {
          e.preventDefault();
          var theme = opt.dataset.theme || "blueprint";
          applyTheme(theme);
          localStorage.setItem("dev-foliio-theme", theme);
          close();
        } else if (e.key === "Escape") {
          e.preventDefault();
          close();
        } else if (e.key === "Tab") {
          // Tab closes panel and lets browser move focus naturally
          close(false);
        }
      });
    });

    // Close on click outside — but not if focus is still inside wrapper
    document.addEventListener("click", function (e) {
      if (!wrapper.contains(e.target)) close(false);
    });

    // Close on Escape when focus is anywhere
    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && isOpen) {
        e.preventDefault();
        close();
      }
    });

    // Load saved theme
    var saved = localStorage.getItem("dev-foliio-theme") || "blueprint";
    applyTheme(saved);
  })();
</script>