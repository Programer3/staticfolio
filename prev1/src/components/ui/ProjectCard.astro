---
// ProjectCard — Card with hover lift, tech chips, links
// Interactive hover reveals actions, click opens detail modal
export interface Props {
  title: string;
  description: string;
  tech: string[];
  github: string;
  demo?: string;
  image: string;
  highlights: string[];
  index: number;
}

const { title, description, tech, github, demo, image, highlights, index } = Astro.props;
const hasDemo = Boolean(demo);
---

<article
  class="paper-card overflow-hidden group transition-all duration-300 hover:shadow-card hover:border-primary/30 hover:-translate-y-1 cursor-pointer project-card"
  role="button"
  tabindex="0"
  aria-label={`Project: ${title}`}
  data-title={title}
  data-desc={description}
  data-tech={tech.join(",")}
  data-github={github}
  data-demo={demo ?? ""}
  data-image={image}
>
  <div class="aspect-video bg-bg-alt relative overflow-hidden">
    <img
      src={image}
      alt={`${title} preview`}
      loading="lazy"
      decoding="async"
      class="absolute inset-0 w-full h-full object-cover opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-300"
      onerror="this.style.display='none';this.parentElement.classList.add('img-fallback')"
    />
    <div class="img-fallback-content absolute inset-0 flex items-center justify-center pointer-events-none">
      <span class="font-display font-bold text-4xl text-fg-muted/20">[ {title.charAt(0)} ]</span>
    </div>
    <div class="absolute inset-0 bg-[var(--theme-bg)]/80 backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center gap-4">
      <a
        href={github}
        target="_blank"
        rel="noopener noreferrer"
        class="px-4 py-2 rounded-full bg-primary text-[var(--theme-bg)] text-xs font-bold hover:scale-105 transition-transform"
        aria-label="View source on GitHub"
      >
        Source
      </a>
      {hasDemo && (
        <a
          href={demo}
          target="_blank"
          rel="noopener noreferrer"
          class="px-4 py-2 rounded-full border border-accent text-accent text-xs font-bold hover:bg-accent hover:text-[var(--theme-bg)] transition-all"
          aria-label="View live demo"
        >
          Live Demo
        </a>
      )}
    </div>
  </div>

  <div class="p-4 sm:p-5" data-project-content="true">
    <h3 class="font-display text-lg font-bold text-fg mb-2 group-hover:text-primary transition-colors">
      {title}
    </h3>
    <p class="font-body text-sm text-fg-muted leading-relaxed line-clamp-2 mb-3">
      {description}
    </p>
    <div class="flex flex-wrap gap-1.5">
      {tech.map((t) => (
        <span class="tag-capsule">
          {t}
        </span>
      ))}
    </div>
  </div>
</article>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    var cards = document.querySelectorAll(".project-card");

    cards.forEach(function (card) {
      var content = card.querySelector("[data-project-content]");

      card.addEventListener("mousemove", function (e) {
        var rect = card.getBoundingClientRect();
        var x = (e.clientX - rect.left) / rect.width - 0.5;
        var y = (e.clientY - rect.top) / rect.height - 0.5;
        content.style.transform = "rotateX(" + (-y * 6) + "deg) rotateY(" + (x * 6) + "deg)";
      });

      card.addEventListener("mouseleave", function () {
        content.style.transform = "rotateX(0) rotateY(0)";
      });

      card.addEventListener("click", function () {
        var title = card.dataset.title || "";
        var desc = card.dataset.desc || "";
        var techs = (card.dataset.tech || "").split(",");
        var github = card.dataset.github || "";
        var demo = card.dataset.demo || "";
        var image = card.dataset.image || "";

        var overlay = document.createElement("div");
        overlay.className = "fixed inset-0 z-[100] flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm animate-scale-in";
        overlay.onclick = function () { overlay.remove(); };

        var modal = document.createElement("div");
        modal.className = "glass-panel max-w-lg w-full p-6 sm:p-8 relative animate-fade-up max-h-[85vh] overflow-y-auto";
        modal.onclick = function (e) { e.stopPropagation(); };

        var chipsHtml = techs.map(function (t) {
          return '<span class="tag-capsule">' + t + '</span>';
        }).join("");

        var demoBtn = demo ? '<a href="' + demo + '" target="_blank" rel="noopener noreferrer" class="px-4 py-2 rounded-full border border-accent text-accent text-xs font-bold">Live Demo</a>' : "";
        var previewHtml = image
          ? '<img src="' + image + '" alt="" class="w-full aspect-video object-cover rounded-xl mb-4 opacity-80" onerror="this.remove()" />'
          : "";

        modal.innerHTML =
          '<button class="absolute top-4 right-4 text-fg-muted hover:text-fg text-2xl transition-colors" aria-label="Close">&times;</button>' +
          previewHtml +
          '<h3 class="font-display text-2xl font-bold text-fg mb-3">' + title + '</h3>' +
          '<p class="font-body text-fg-muted leading-relaxed mb-4">' + desc + '</p>' +
          '<div class="flex flex-wrap gap-1.5 mb-4">' + chipsHtml + '</div>' +
          '<div class="flex gap-3">' +
            '<a href="' + github + '" target="_blank" rel="noopener noreferrer" class="px-4 py-2 rounded-full command-strip text-xs font-bold">View Source</a>' +
            demoBtn +
          '</div>';

        modal.querySelector("button").onclick = function () { overlay.remove(); };
        overlay.appendChild(modal);
        document.body.appendChild(overlay);
      });
    });
  });
</script>
