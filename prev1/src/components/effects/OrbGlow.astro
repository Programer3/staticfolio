---
// Floating gradient orbs that follow cursor subtly
---

<div class="fixed inset-0 pointer-events-none z-[1] overflow-hidden" aria-hidden="true">
  <div
    id="orb-1"
    class="absolute -top-1/4 -left-1/4 w-[60vmax] h-[60vmax] rounded-full"
    style="background: radial-gradient(circle, var(--theme-orb-1) 0%, transparent 70%);"
  />
  <div
    id="orb-2"
    class="absolute -bottom-1/4 -right-1/4 w-[50vmax] h-[50vmax] rounded-full"
    style="background: radial-gradient(circle, var(--theme-orb-2) 0%, transparent 70%);"
  />
  <div
    id="orb-3"
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[70vmax] h-[70vmax] rounded-full"
    style="background: radial-gradient(circle, var(--theme-orb-3) 0%, transparent 70%);"
  />
</div>

<script>
  var orbs = [
    document.getElementById("orb-1"),
    document.getElementById("orb-2"),
    document.getElementById("orb-3"),
  ];

  var mouseX = 0;
  var mouseY = 0;

  document.addEventListener("mousemove", function (e) {
    mouseX = e.clientX / window.innerWidth - 0.5;
    mouseY = e.clientY / window.innerHeight - 0.5;
  });

  function animateOrbs() {
    var factor = 15;
    orbs[0].style.transform = "translate(" + (mouseX * factor) + "px, " + (mouseY * factor) + "px)";
    orbs[1].style.transform = "translate(" + (-mouseX * factor * 0.7) + "px, " + (-mouseY * factor * 0.7) + "px)";
    orbs[2].style.transform = "translate(" + (mouseX * factor * 0.4) + "px, " + (mouseY * factor * 0.4) + "px)";
    requestAnimationFrame(animateOrbs);
  }

  if (orbs[0] && orbs[1] && orbs[2]) {
    animateOrbs();
  }
</script>